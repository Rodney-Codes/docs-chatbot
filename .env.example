# Chatbot service runtime configuration
CHATBOT_INDEX_ROOT=data/index
CHAT_ALLOW_FALLBACK=true
CORS_ALLOW_ORIGINS=http://localhost:5173
# In-memory logging for tests/local only (no persistent database).
CHAT_LOG_ENABLED=false

# Optional Hugging Face settings
HF_CHAT_API_URL=https://router.huggingface.co/v1/chat/completions
HF_MODEL=
HF_MODEL_FALLBACKS=meta-llama/Llama-3.1-8B-Instruct:novita
HF_API_TOKEN=

# Optional default artifact URLs (can also be passed per API request).
# CHATBOT_CHUNKS_URL=
# CHATBOT_VECTOR_INDEX_URL=
